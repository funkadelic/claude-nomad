{
  // markdownlint-cli2 options; rule config lives in .markdownlint.json (shared
  // with the editor extension). `gitignore: true` skips everything in
  // .gitignore (node_modules, build output, and local-only trees), so only
  // committed Markdown is linted. CHANGELOG.md is committed but generated by
  // release-please, so it is excluded explicitly. Note: .markdownlintignore is
  // a markdownlint-cli v1 feature that cli2 does not read; exclusions live here.
  // The plugin command files under .claude-plugin/nomad-plugin/commands/ are
  // YAML frontmatter plus a single bash-injection line, not prose Markdown, so
  // they are excluded; the plugin README stays linted like any other doc.
  "globs": ["**/*.md"],
  "gitignore": true,
  "ignores": [
    "CHANGELOG.md",
    "docs-site/**",
    ".claude-plugin/nomad-plugin/commands/**",
  ],
}
